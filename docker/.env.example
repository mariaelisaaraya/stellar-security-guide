# =============================================================================
#  .env.example  -  Copy this file to '.env' and fill in the values.
#  Never commit the real .env to a public repo.
# =============================================================================

# Your RPC domain (its DNS must point to this server's IP).
# Used by the Caddyfile via the {$RPC_DOMAIN} placeholder.
RPC_DOMAIN=rpc.yourdomain.com

# NOTE: the Stellar network selection (testnet vs pubnet) is NOT set here.
# It lives inside config/stellar-rpc-config.toml (NETWORK_PASSPHRASE and
# HISTORY_ARCHIVE_URLS) and config/stellar-captive-core.cfg.
# For reference:
#   - Testnet passphrase: "Test SDF Network ; September 2015"
#   - Pubnet passphrase:  "Public Global Stellar Network ; September 2015"
# Always start on TESTNET.
